{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 120,
	"tabWidth": 2,
	"useTabs": true,
	"semi": false,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": true,
	"singleAttributePerLine": true,
	"arrowParens": "always",
	"proseWrap": "preserve",
	"embeddedLanguageFormatting": "auto",
	"htmlWhitespaceSensitivity": "css",
	"vueIndentScriptAndStyle": true,
	"endOfLine": "lf",
	"jsxSingleQuote": true,
	"ignorePatterns": [
		".agent/**",
		".codex/**",
		".cursor/**",
		".git/**",
		".vscode/**",
		"Documents/**",
		"auto-imports.d.ts",
		"bun.lock*",
		"components.d.ts",
		"dist/**",
		"node_modules/**",
		"openspec/**",
		"release-output/**",
		"src-tauri/**",
		"StoneFlow.code-workspace",
		"tsconfig*.tsbuildinfo",
		".DS_Store",
		"*.md"
	],
	"overrides": [
		{
			"files": ["*.json"],
			"options": {
				"printWidth": 80
			}
		},
		{
			"files": ["*.vue"],
			"options": {
				"bracketSameLine": true,
				"singleAttributePerLine": true,
				"htmlWhitespaceSensitivity": "ignore"
			}
		},
		{
			"files": ["*.css"],
			"options": {
				"singleQuote": false,
				"useTabs": true
			}
		},
		{
			"files": ["*.yml", "*.yaml"],
			"options": {
				"singleQuote": false,
				"tabWidth": 2
			}
		}
	]
}
